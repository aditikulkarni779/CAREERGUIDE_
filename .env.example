ENV=local

# ---- LLM (free dev tier) ----
# LLM_PROVIDER options: gemini | groq | openrouter | anthropic
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY: add for prod tiering
ANTHROPIC_API_KEY=

# ---- Embeddings ----
# EMBED_PROVIDER options: gemini | voyage | bge_local
EMBED_PROVIDER=gemini
VOYAGE_API_KEY=

# ---- Datastores (local docker defaults) ----
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=career-copilot

# ---- Integrations ----
GITHUB_TOKEN=
OAUTH_GITHUB_ID=
OAUTH_GITHUB_SECRET=
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Observability ----
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# ---- Auth ----
JWT_SECRET=change-me-in-prod
NEXTAUTH_SECRET=change-me-in-prod
LOG_LEVEL=INFO
